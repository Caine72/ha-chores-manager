#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")"
  pwd
)"
REPO_ROOT="$(git -C "${SCRIPT_DIR}" rev-parse --show-toplevel)"
OUTPUT_FILE="${1:-${REPO_ROOT}/chores-manager-context.txt}"
OUTPUT_FILE="$(realpath -m -- "${OUTPUT_FILE}")"

cd "${REPO_ROOT}"

if [[ -e "${OUTPUT_FILE}" && -d "${OUTPUT_FILE}" ]]; then
  printf 'Error: output path is a directory: %s\n' "${OUTPUT_FILE}" >&2
  exit 1
fi

mkdir -p -- "$(dirname -- "${OUTPUT_FILE}")"

output_relative_path=""
if [[ "${OUTPUT_FILE}" == "${REPO_ROOT}"/* ]]; then
  output_relative_path="${OUTPUT_FILE#"${REPO_ROOT}"/}"
fi

mapfile -t tracked_files < <(
  git ls-files |
    LC_ALL=C sort
)

# Include selected untracked files that are useful during handoff before they
# have been committed. Other untracked files remain excluded to avoid leaking
# local configuration, secrets, patches, generated snapshots, or scratch work.
mapfile -t additional_context_files < <(
  git ls-files --others --exclude-standard |
    while IFS= read -r file; do
      case "${file}" in
        AGENTS.md | */AGENTS.md | docs/*.md)
          printf '%s\n' "${file}"
          ;;
      esac
    done |
    LC_ALL=C sort -u
)

declare -A seen_files=()
context_files=()

for file in "${tracked_files[@]}" "${additional_context_files[@]}"; do
  [[ -n "${file}" ]] || continue

  # Never embed the generated snapshot into itself, even if it is tracked.
  if [[ -n "${output_relative_path}" && "${file}" == "${output_relative_path}" ]]; then
    continue
  fi

  if [[ -n "${seen_files[${file}]+set}" ]]; then
    continue
  fi

  seen_files["${file}"]=1
  context_files+=("${file}")
done

mapfile -t context_files < <(
  printf '%s\n' "${context_files[@]}" |
    LC_ALL=C sort -u
)

agent_instruction_files=()
project_documentation_files=()

for file in "${context_files[@]}"; do
  case "${file}" in
    AGENTS.md | */AGENTS.md)
      agent_instruction_files+=("${file}")
      ;;
  esac

  case "${file}" in
    docs/*.md)
      project_documentation_files+=("${file}")
      ;;
  esac
done

print_file_list() {
  local -n files_ref="$1"

  if ((${#files_ref[@]} == 0)); then
    printf '%s\n' '(none)'
    return
  fi

  printf '%s\n' "${files_ref[@]}"
}

{
  printf '%s\n\n' '# Chores Manager source snapshot'

  printf '%s\n' '## Generated'
  date --iso-8601=seconds
  printf '\n'

  printf '%s\n' '## Repository'
  printf '%s\n\n' "${REPO_ROOT}"

  printf '%s\n' '## Current branch'
  git branch --show-current
  printf '\n'

  printf '%s\n' '## Current commit'
  git rev-parse HEAD
  printf '\n'

  printf '%s\n' '## Git status'
  git status --short --branch
  printf '\n'

  printf '%s\n' '## Recent commits'
  git --no-pager log \
    --oneline \
    --decorate \
    --max-count=10
  printf '\n'

  printf '%s\n' '## Repository remotes'
  git remote -v || true
  printf '\n'

  printf '%s\n' '## Agent instruction files'
  print_file_list agent_instruction_files
  printf '\n'

  printf '%s\n' '## Project documentation files'
  print_file_list project_documentation_files
  printf '\n'

  printf '%s\n' '## Additional untracked context files'
  print_file_list additional_context_files
  printf '\n'

  printf '%s\n' '## Tracked file inventory'
  for file in "${tracked_files[@]}"; do
    if [[ -n "${output_relative_path}" && "${file}" == "${output_relative_path}" ]]; then
      continue
    fi

    printf '%s\n' "${file}"
  done
  printf '\n'

  printf '%s\n\n' '## Source files'

  for file in "${context_files[@]}"; do
    [[ -f "${file}" ]] || continue

    printf '===== %s =====\n' "${file}"

    # Include empty and text files. Binary files remain visible in the
    # inventory but their contents are omitted from the snapshot.
    if [[ ! -s "${file}" ]] || grep -Iq '' -- "${file}"; then
      cat -- "${file}"

      # Ensure the separator starts on a fresh line when a source file itself
      # does not end with a newline.
      if [[ -s "${file}" ]]; then
        last_byte="$(
          tail -c 1 -- "${file}" |
            od -An -t x1 |
            tr -d '[:space:]'
        )"

        if [[ "${last_byte}" != '0a' ]]; then
          printf '\n'
        fi
      fi
    else
      printf '%s\n' '[Binary file omitted]'
    fi

    printf '\n'
  done
} >"${OUTPUT_FILE}"

printf 'Generated: %s\n' "${OUTPUT_FILE}"
